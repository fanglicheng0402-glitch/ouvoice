generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetStatus {
  REVIEWING
  CERTIFIED
  LICENSED
  REJECTED
}

enum TaskDifficulty {
  EASY
  STANDARD
  ADVANCED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum EarningType {
  TASK
  LICENSE
}

enum MintLicenseTier {
  ECOSYSTEM_CORE
  GLOBAL_TRAINING
  RESEARCH_ONLY
  NO_AI_USAGE
}

model User {
  id               String       @id @default(cuid())
  phone            String       @unique
  name             String
  region           String
  dialect          String
  voiceprintHash   String?      @unique
  identityVerified Boolean      @default(false)
  contributorLevel Int          @default(1)
  contributionDays Int          @default(0)
  createdAt        DateTime     @default(now())
  wallet           Wallet?
  recordings       Recording[]
  assets           VoiceAsset[]
  earnings         Earning[]
  taskClaims       TaskClaim[]
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  pending   Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CollectionTask {
  id          String         @id @default(cuid())
  title       String
  dialect     String
  region      String
  reward      Decimal        @db.Decimal(10, 2)
  durationMin Int
  durationMax Int
  difficulty  TaskDifficulty
  category    String
  quota       Int
  claimed     Int            @default(0)
  deadline    DateTime
  script      String
  accentTip   String
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  claims      TaskClaim[]
  recordings  Recording[]
}

model TaskClaim {
  id        String         @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime       @default(now())
  task      CollectionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model Recording {
  id             String          @id @default(cuid())
  userId         String
  taskId         String?
  title          String
  objectKey      String
  duration       Int
  mimeType       String
  qualityScore   Int?
  consentVersion String
  createdAt      DateTime        @default(now())
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  task           CollectionTask? @relation(fields: [taskId], references: [id])
  asset          VoiceAsset?
}

model VoiceAsset {
  id          String         @id @default(cuid())
  serial      String         @unique
  userId      String
  recordingId String         @unique
  status      AssetStatus    @default(REVIEWING)
  fingerprint String         @unique
  txHash      String?        @unique
  chainId     String         @default("ouvoice-testnet-1")
  metadataUri String?
  mintedAt    DateTime?
  mintLicenseTier  MintLicenseTier?
  mintLicensePrice Decimal?          @db.Decimal(10, 2)
  mintConfirmedAt DateTime?
  sovereigntyRevokedAt DateTime?
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  recording   Recording      @relation(fields: [recordingId], references: [id], onDelete: Restrict)
  offers      LicenseOffer[]
  earnings    Earning[]
  usageLedgers UsageLedger[]

  @@index([userId, status])
}

model UsageLedger {
  id              String     @id @default(cuid())
  assetId         String
  occurredAt      DateTime   @default(now())
  durationSeconds Decimal    @db.Decimal(12, 3)
  ratePerSecond   Decimal    @db.Decimal(10, 4)
  earningsCny     Decimal    @db.Decimal(14, 4)
  description     String
  asset           VoiceAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, occurredAt])
}

model LicenseOffer {
  id            String      @id @default(cuid())
  assetId       String
  licenseeName  String
  licenseeDid   String
  purpose       String
  amount        Decimal     @db.Decimal(12, 2)
  durationMonths Int
  exclusive     Boolean     @default(false)
  territory     String      @default("中国大陆")
  status        OfferStatus @default(PENDING)
  agreementHash String?
  acceptedAt    DateTime?
  createdAt     DateTime    @default(now())
  asset         VoiceAsset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Earning {
  id          String      @id @default(cuid())
  userId      String
  assetId     String?
  type        EarningType
  title       String
  source      String
  amount      Decimal     @db.Decimal(12, 2)
  settledAt   DateTime?
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset       VoiceAsset? @relation(fields: [assetId], references: [id])

  @@index([userId, createdAt])
}
